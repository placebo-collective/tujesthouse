{
  "name": "tujesthouse-app",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev",
    "dev:tina": "tinacms dev -c \"next dev\"",
    "build": "next build",
    "build:gh-pages": "next build && cp CNAME out/ && cp .nojekyll out/",
    "start": "npx serve@latest out -s",
    "preview": "npx serve@latest out -s",
    "lint": "eslint . --fix && npx tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "prepush": "npx tsc && npm run lint && npm run format"
  },
  "dependencies": {
    "@tinacms/cli": "^2.1.9",
    "next": "^16.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "tinacms": "^3.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "25.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.2.3",
    "eslint": "^9.29.0",
    "eslint-config-next": "^16.1.0",
    "globals": "^16.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
