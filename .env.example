# Tina CMS Configuration
# Copy this file to .env and fill in your credentials

# Get these from https://app.tina.io after creating a project
NEXT_PUBLIC_TINA_CLIENT_ID=your_client_id_here
TINA_TOKEN=your_token_here

# For local development - set to true to work offline
TINA_PUBLIC_IS_LOCAL=true

# Google reCAPTCHA v3 - https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Google Apps Script Web App URL (handles form submissions, sheets, email)
NEXT_PUBLIC_APPS_SCRIPT_URL=your_apps_script_web_app_url_here
